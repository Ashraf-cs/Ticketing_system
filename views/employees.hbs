<script src="/employees.js" onload="getTickets()"></script>
<div class="container mt-3">

    <button id="create" class="btn btn-sm btn-success" data-bs-toggle="collapse" data-bs-target="#createTicket">Create ticket</button>
    <div class="collapse mt-2" id="createTicket">
        <form method="get" style="background-color: white;" onsubmit="preventSubmit(event)">
            <div class="row row-cols-2">
                <div class="col">
                    <label for="name" class="form-label mt-1 mb-1 fw-bold">Name</label>
                    <input type="text" name="name" id="name" class="form-control form-control-sm" readonly value={{name}} />
                </div>
                <div class="col">
                    <label for="phone" class="form-label mt-1 mb-1 fw-bold">Phone</label>
                    <input type="text" name="phone" id="phone" class="form-control form-control-sm" required pattern="[0-9]+"/>
                    <div class="invalid-feedback" id="invalid-feedback"></div>
                </div>
                <div class="col">
                    <label for="company" class="form-label mt-2 mb-1 fw-bold">Company</label>
                    <input type="text" name="company" id="company" class="form-control form-control-sm" readonly value={{company}} />
                </div>
                <div class="col">
                    <label for="category" class="form-label mt-2 mb-1 fw-bold">Category</label>
                    <select name="category" id="category" class="form-select form-select-sm" required>
                        <option value="" selected disabled></option>
                        <option value="devices">Devices</option>
                        <option value="network">Network</option>
                        <option value="printers">Printers</option>
                    </select>
                </div>
                <div class="col-12">
                    <label for="description" class="form-label mt-2 mb-1 fw-bold">Description</label>
                    <textarea name="description" id="description" class="form-control form-control-sm" rows="4" cols="50" maxlength="500"
                    placeholder="Write description for the issue" required></textarea>
                </div>

            </div>
            <input id="submit" type="submit" value="Send" class="btn btn-sm btn-primary mt-2" style="width: 80px" onclick="sendTicket(event)"/>

        </form>
    </div>

    <div class="mt-4">
        <h5>Your tickets</h5>
        <div style="overflow: auto; height: 300px">
            <table class="table table-striped table-hover" >
                <thead>
                    <tr>
                        <th>Number</th>
                        <th>Created at</th>
                        <th>Company</th>
                        <th>Phone</th>
                        <th>Category</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Closed at</th>
                        <td></td>
                    </tr>
                </thead>
                <tbody id="tickets">

                </tbody>
        </table>
        </div>
    </div>
</div>
